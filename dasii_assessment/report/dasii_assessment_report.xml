<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Define the Report Action -->
    <record id="action_report_dasii_assessment" model="ir.actions.report">
        <field name="name">DASII Assessment Report</field>
        <field name="model">dasii.assessment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">dasii_assessment.report_dasii_assessment_document</field>
        <field name="report_file">dasii_assessment.report_dasii_assessment_document</field>
        <field name="print_report_name">'DASII Assessment - %s' % (object.partner_id.name)</field>
        <field name="binding_model_id" ref="model_dasii_assessment"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Define the Report Template -->
    <template id="report_dasii_assessment_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="oe_structure"/>
                        
                        <h2 class="text-center mt-4">Developmental Assessment Scale for Indian Infants (DASII)</h2>
                        <h4 class="text-center mb-4">Assessment Report</h4>

                        <!-- Patient Details -->
                        <div class="row mt-4 mb-4" id="patient_details">
                            <div class="col-6">
                                <strong>Patient:</strong>
                                <span t-field="o.partner_id"/>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Assessment Date:</strong>
                                <span t-field="o.assessment_date" t-options='{"widget": "date"}'/>
                            </div>
                            <div class="col-6">
                                <strong>Date of Birth:</strong>
                                <span t-field="o.date_of_birth" t-options='{"widget": "date"}'/>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Age (Months):</strong>
                                <span t-esc="round(o.age_months, 2)"/>
                            </div>
                        </div>

                        <!-- Score Summary -->
                        <h3 class="mt-4 border-bottom pb-2">Score Summary</h3>
                        <div class="row mt-3 mb-4">
                            <div class="col-6">
                                <h5>Motor Development</h5>
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td><strong>Raw Score:</strong></td>
                                        <td><span t-field="o.motor_raw_score"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Developmental Age (DA):</strong></td>
                                        <td><span t-field="o.motor_da"/> months</td>
                                    </tr>
                                    <tr>
                                        <td><strong>Developmental Quotient (DQ):</strong></td>
                                        <td><strong><span t-esc="round(o.motor_dq, 2)"/></strong></td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <h5>Mental Development</h5>
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td><strong>Raw Score:</strong></td>
                                        <td><span t-field="o.mental_raw_score"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Developmental Age (DA):</strong></td>
                                        <td><span t-field="o.mental_da"/> months</td>
                                    </tr>
                                    <tr>
                                        <td><strong>Developmental Quotient (DQ):</strong></td>
                                        <td><strong><span t-esc="round(o.mental_dq, 2)"/></strong></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Cluster Scores -->
                        <t t-if="o.cluster_score_ids">
                            <h3 style="page-break-before: always;" class="mt-4 border-bottom pb-2">Cluster Analysis</h3>
                            <table class="table table-sm table-bordered mt-3 text-center">
                                <thead style="background-color: #f8f9fa;">
                                    <tr>
                                        <th class="text-start">Scale</th>
                                        <th class="text-start">Cluster Name</th>
                                        <th>Total Items</th>
                                        <th>Passed Items</th>
                                        <th>Performance (%)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.cluster_score_ids.sorted(key=lambda c: (c.cluster_scale, c.cluster_id.sequence))" t-as="cluster">
                                        <tr>
                                            <td class="text-start"><span t-field="cluster.cluster_scale"/></td>
                                            <td class="text-start"><span t-field="cluster.cluster_name"/></td>
                                            <td><span t-field="cluster.total_items"/></td>
                                            <td><span t-field="cluster.yes_count"/></td>
                                            <td>
                                                <t t-if="cluster.total_items > 0">
                                                    <span t-esc="round((cluster.yes_count / cluster.total_items) * 100, 1)"/>%
                                                </t>
                                                <t t-else="">
                                                    -
                                                </t>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Detailed Items -->
                        <t t-if="o.line_ids">
                            <h3 style="page-break-before: always;" class="mt-4 border-bottom pb-2">Detailed Assessment Lines</h3>
                            
                            <!-- Filter Motor Lines -->
                            <t t-set="motor_lines" t-value="o.line_ids.filtered(lambda l: l.item_scale == 'motor').sorted('item_no')"/>
                            <t t-if="motor_lines">
                                <h4 class="mt-3">Motor Scale</h4>
                                <table class="table table-sm table-bordered">
                                    <thead style="background-color: #e9ecef;">
                                        <tr>
                                            <th style="width: 10%;">Item No</th>
                                            <th style="width: 70%;">Description</th>
                                            <th style="width: 20%;" class="text-center">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="motor_lines" t-as="line">
                                            <td><span t-field="line.item_no"/></td>
                                            <td><span t-field="line.item_description"/></td>
                                            <td class="text-center">
                                                <span t-if="line.status == 'yes'" class="badge text-bg-success">Passed</span>
                                                <span t-elif="line.status == 'no'" class="badge text-bg-danger">Failed</span>
                                                <span t-else="" class="badge text-bg-secondary">Not Assessed</span>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </t>

                            <!-- Filter Mental Lines -->
                            <t t-set="mental_lines" t-value="o.line_ids.filtered(lambda l: l.item_scale == 'mental').sorted('item_no')"/>
                            <t t-if="mental_lines">
                                <h4 class="mt-4">Mental Scale</h4>
                                <table class="table table-sm table-bordered">
                                    <thead style="background-color: #fff3cd;">
                                        <tr>
                                            <th style="width: 10%;">Item No</th>
                                            <th style="width: 70%;">Description</th>
                                            <th style="width: 20%;" class="text-center">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="mental_lines" t-as="line">
                                            <td><span t-field="line.item_no"/></td>
                                            <td><span t-field="line.item_description"/></td>
                                            <td class="text-center">
                                                <span t-if="line.status == 'yes'" class="badge text-bg-success">Passed</span>
                                                <span t-elif="line.status == 'no'" class="badge text-bg-danger">Failed</span>
                                                <span t-else="" class="badge text-bg-secondary">Not Assessed</span>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </t>
                        </t>

                        <div class="oe_structure"/>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
